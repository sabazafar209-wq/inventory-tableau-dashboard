      <aliases enabled='yes' />
      <column caption='Inventory Value' datatype='real' name='[Calculation_2436578404909060]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Closing_Stock] * [Unit_Cost]' />
      </column>
      <column caption='Stockout Indicator' datatype='integer' name='[Calculation_2436578405011461]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Stockout_Flag] = &quot;Yes&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Stockout Rate' datatype='real' name='[Calculation_2436578405109766]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_2436578405011461]) / COUNT([Product_ID])' />
      </column>
      <column caption='Average Invenotry' datatype='real' name='[Calculation_2436578405175303]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Opening_Stock] + [Closing_Stock]) / 2' />
      </column>
      <column caption='Inventory Turnover' datatype='real' name='[Calculation_2436578405433352]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Units_Sold]) / AVG([Calculation_2436578405175303])' />
      </column>
